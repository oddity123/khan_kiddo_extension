{
  "manifest_version": 3,
  "name": "对话批量分析",
  "description": "在网页中勾选多条对话文本，于侧边栏批量查看分析结果。",
  "version": "1.0.0",
  "permissions": ["storage", "tabs", "activeTab", "sidePanel"],
  "host_permissions": ["https://www.doubao.com/*", "https://doubao.com/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.doubao.com/*", "https://doubao.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
