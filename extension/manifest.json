{
  "manifest_version": 3,
  "name": "KhanKiddo",
  "description": "KhanKiddo：在豆包对话中勾选你的用户消息，于侧栏批量整理并用 KhanKiddo 发起分析。",
  "version": "1.0.0",
  "permissions": ["storage", "tabs", "activeTab", "sidePanel"],
  "host_permissions": ["https://www.doubao.com/*", "https://doubao.com/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.doubao.com/*", "https://doubao.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
